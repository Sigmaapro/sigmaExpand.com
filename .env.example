# Public site URL for metadataBase, canonical paths, sitemap, robots, and Open Graph (no trailing slash).
# Set on Vercel Production to your stable hostname so canonicals never point at preview deployment URLs.
NEXT_PUBLIC_SITE_URL=https://sigmaa.pro

# Insights / blog link in the main nav. Leave unset to use the built-in app route `/insights`.
# NEXT_PUBLIC_INSIGHTS_URL=/insights

# Optional: override support (headphones) button URL. If unset, opens /contact in a new tab.
# NEXT_PUBLIC_LIVE_SUPPORT_URL=https://example.com/support

# Optional: Calendly inline embed for “Book a Call” modal (Calendly → Add to Website).
# If unset, the modal shows the lead form (POST /api/contact).
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-team/strategy-call?embed_domain=sigmaa.pro&embed_type=Inline

# Social & contact hub (/contact) — set any subset; only non-empty values are shown.
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/yourhandle
# NEXT_PUBLIC_SOCIAL_X=https://x.com/yourhandle
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/yourcompany
# NEXT_PUBLIC_SOCIAL_TELEGRAM=https://t.me/yourchannel
# NEXT_PUBLIC_SOCIAL_DISCORD=https://discord.gg/yourinvite
# NEXT_PUBLIC_SOCIAL_EMAIL=BD@sigmaa.pro
# NEXT_PUBLIC_SOCIAL_WEBSITE=https://sigmaa.pro

# --- Lead capture (POST /api/contact) — server only; never use NEXT_PUBLIC_ for secrets ---

# Required for email delivery: Resend API key + inbox that receives leads.
RESEND_API_KEY=re_xxxxxxxx
CONTACT_EMAIL=BD@sigmaa.pro

# Verified sender in Resend (production: use a domain you control, e.g. sigmaa.pro).
# Resend dashboard → Domains → verify DNS before go-live.
# EMAIL_FROM=Sigma <leads@sigmaa.pro>
# FROM_EMAIL=Sigma <leads@sigmaa.pro>
# Fallback if unset: Sigma <onboarding@resend.dev> (testing only)

# Alias accepted instead of RESEND_API_KEY:
# EMAIL_API_KEY=re_xxxxxxxx

# Optional: Telegram notifications (BotFather token + chat id). Failure does not block email if email succeeds.
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789
