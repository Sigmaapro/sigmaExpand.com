# Public site URL for canonical links, sitemap, robots, and Open Graph (no trailing slash).
# Required for correct SEO in production. On Vercel you can rely on VERCEL_URL if unset.
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com

# Insights / blog link in the main nav. Leave unset to use the built-in app route `/insights`.
# Only set this if Insights is hosted on another domain (must be a real, reachable URL).
# NEXT_PUBLIC_INSIGHTS_URL=/insights
# NEXT_PUBLIC_INSIGHTS_URL=https://your-real-blog.com

# Optional: override support (headphones) button URL. If unset, opens /contact in a new tab.
# NEXT_PUBLIC_LIVE_SUPPORT_URL=https://example.com/support

# Optional: Calendly embed URL for “Book a Call” (inline embed from Calendly → Add to Website).
# If unset, the modal shows the lead form (submits to /api/contact).
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-org/30min?embed_domain=localhost&embed_type=Inline

# Social & contact hub (/contact) — set any subset; only non-empty values are shown.
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/yourhandle
# NEXT_PUBLIC_SOCIAL_X=https://x.com/yourhandle
# NEXT_PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/yourcompany
# NEXT_PUBLIC_SOCIAL_TELEGRAM=https://t.me/yourchannel
# NEXT_PUBLIC_SOCIAL_DISCORD=https://discord.gg/yourinvite
# NEXT_PUBLIC_SOCIAL_EMAIL=hello@example.com
# NEXT_PUBLIC_SOCIAL_WEBSITE=https://sigma.example

# --- Lead capture (/api/contact) — server only; never expose keys with NEXT_PUBLIC_
# Inbound email address for Resend (who receives lead notifications).
CONTACT_EMAIL=leads@yourdomain.com
# Resend API key (create at https://resend.com). Also accepts EMAIL_API_KEY as an alias.
RESEND_API_KEY=re_xxxxxxxx
# EMAIL_API_KEY=re_xxxxxxxx
# Verified sender in Resend (use onboarding@resend.dev only for testing).
# EMAIL_FROM=Sigma <onboarding@resend.dev>
# FROM_EMAIL=Sigma <notifications@yourdomain.com>

# Optional: Telegram notifications (BotFather token + numeric chat id or @channelusername).
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789
